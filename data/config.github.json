  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 12,
    "max_items": 20,
    "category_groups": {
      "equities": {
        "name": "股市行情",
        "limit": 5,
        "categories": ["equities-cn", "equities-us", "finance-equities"]
      },
      "macro": {
        "name": "宏观与全球",
        "limit": 4,
        "categories": ["finance-global", "finance-macro"]
      },
      "deep": {
        "name": "深度分析",
        "limit": 4,
        "categories": ["finance-deep", "finance-general"]
      },
      "flash": {
        "name": "实时快讯",
        "limit": 3,
        "categories": ["finance-flash"]
      },
      "tech": {
        "name": "科技与AI",
        "limit": 2,
        "categories": ["finance-tech", "finance-ai"]
      },
      "community": {
        "name": "社区热点",
        "limit": 2,
        "categories": ["community"]
      }
    },
    "default_group": "other",
    "default_group_limit": 3
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
