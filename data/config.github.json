          "symbols": ["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA"]
        }
      ]
    },
    "google_news": {
      "enabled": true,
      "query": "财经 OR 股市 OR A股 OR 美股 OR 港股 OR 宏观经济",
      "language": "zh",
      "country": "CN",
      "ceid": null,
      "max_results": 80,
      "category": "finance-search"
    },
    "ossinsight": {
      "enabled": false
    },
    "gdelt": {
      "enabled": false
    }
